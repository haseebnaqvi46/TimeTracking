<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Time Tracking</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">

        <div class="container-fluid">

            <a class="navbar-brand" href="/">TimeTracking</a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home"
                           asp-action="Index">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           @*asp-controller="TimeEntries"*@
                          @* asp-action="Index">*@
                          href="TimeEntries/index">
                          Time Entries
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           @*asp-controller="Summary"
                           asp-action="Weekly">*@
                           href="Summary/Weekly">
                            Weekly Summary
                        </a>
                    </li>

                </ul>

            </div>

        </div>

    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

</body>
</html>