@using TimeTracking.App.ViewModels
@model List<WeeklySummaryViewModel>

<h2>Weekly Summary</h2>

<table class="table">

    <thead>
        <tr>
            <th>Employee</th>
            <th>Total Hours</th>
            <th>Overtime</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EmployeeName</td>
                <td>@item.TotalHours</td>
                <td>
                    @if (item.IsOvertime)
                    {
                        <span style="color:red">Overtime</span>
                    }
                    else
                    {
                        <span>Normal</span>
                    }
                </td>
            </tr>
        }

    </tbody>
</table>