@using TimeTracking.App.ViewModels
@model List<TimeEntryViewModel>

<h2>Time Entries</h2>

<table class="table">

    <thead>
        <tr>
            <th>Employee</th>
            <th>Project</th>
            <th>Date</th>
            <th>Hours</th>
            <th>Notes</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EmployeeName</td>
                <td>@item.ProjectName</td>
                <td>@item.EntryDate.ToShortDateString()</td>
                <td>@item.Hours</td>
                <td>@item.Notes</td>
            </tr>
        }

    </tbody>

</table>